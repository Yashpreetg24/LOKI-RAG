# ── ENVIRONMENT MODE ──────────────────────────────────────────────────────────
# Set RENDER=1 or PRODUCTION=1 to force Groq + Pinecone mode.
# If unset, the app defaults to Local Mode (Ollama + ChromaDB).
RENDER=0

# ── LOCAL MODE (Ollama + ChromaDB) ───────────────────────────────────────────
# Ensure Ollama is running and you have pulled the model: ollama pull gemma:2b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b

# ── HOSTED MODE (Groq + Pinecone) ───────────────────────────────────────────
# Required if RENDER=1 or PRODUCTION=1
# Supports multiple keys for failover (comma-separated):
#   GROQ_API_KEY=key1,key2,key3
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

PINECONE_API_KEY=
PINECONE_INDEX=rag-terminal

# Supports multiple tokens for failover (comma-separated):
#   HF_TOKEN=hf_token1,hf_token2
HF_TOKEN=

# ── SYSTEM SETTINGS ─────────────────────────────────────────────────────────
FLASK_PORT=5001
FLASK_DEBUG=true

# Embedding model (shared across modes)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Storage paths
CHROMA_PERSIST_DIR=./chroma_db
UPLOAD_FOLDER=./uploads
