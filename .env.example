# ── LOKI_SYSTEM OPERATIONAL MODES ──────────────────────────────────────────
# Set LOKI_HOSTED_MODE=1 to bypass local nodes and use Cloud Vitals (Groq + Pinecone).
LOKI_HOSTED_MODE=0

# ── Ollama (local LLM — used in local mode) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4-e2b

# ── CLOUD INTELLIGENCE (Groq) ────────────────────────────────────────────────
LOKI_VAULT_TOKEN=your_groq_api_key_here
LOKI_CLOUD_BRAIN=llama-3.1-8b-instant

# ── VECTOR REPOSITORY (Pinecone) ──────────────────────────────────────────────
LOKI_VECTOR_KEY=your_pinecone_api_key_here
LOKI_VECTOR_INDEX=your_index_name_here

# ── SEMANTIC CORE (Local Vector Store) ────────────────────────────────────────
LOKI_EMBED_CORE=sentence-transformers/all-MiniLM-L6-v2
LOKI_LOCAL_VAULT=./chroma_db
LOKI_CELL_ID=documents

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=pdf,txt,md
