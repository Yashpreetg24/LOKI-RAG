# ── Environment ──────────────────────────────────────────────────────────────
# Set RENDER=1 or PRODUCTION=1 to switch to hosted mode (Groq + Pinecone).
# Leave both unset for local mode (Ollama + ChromaDB).
# RENDER=1
# PRODUCTION=1

# ── Ollama (local LLM — used in local mode) ───────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4-e2b

# ── Groq (hosted LLM — required in hosted mode, optional Ollama fallback locally)
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Pinecone (hosted vector store — required in hosted mode) ──────────────────
# Get a key at https://app.pinecone.io  |  Create a free serverless index first.
PINECONE_API_KEY=
PINECONE_INDEX=rag-terminal

# ── Embedding Model (used in both modes) ──────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ChromaDB (local vector store — used in local mode only) ───────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=documents

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=pdf,txt,md
